{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "skipLibCheck": true,
    "allowJs": true,
    "declaration": true,
    "outDir": "out/pkg",
    "rootDir": "out/src"
  },
  "include": ["out/src/**/*.ts", "out/src/**/*.js", "types/**/*.d.ts"]
}
